#!/bin/bash

set -e

PLUGIN_SLUG="wpcn-unlinker"
PLUGIN_FILE="${PLUGIN_SLUG}.php"
BUILD_ZIP="build/${PLUGIN_SLUG}.zip"

echo "🚀 Running pre-push checks..."

# -----------------------------
# Helper
# -----------------------------
run_check() {
  local LABEL="$1"
  shift

  echo ""
  echo "$LABEL"

  "$@"
  local status=$?

  if [ $status -ne 0 ]; then
    echo "❌ Check failed."
    exit $status
  fi
}

# -----------------------------
# 1. Ensure working tree is clean
# -----------------------------
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo ""
  echo "❌ Your working tree is not clean."
  echo "👉 Commit or stash your changes before pushing."
  exit 1
fi

# -----------------------------
# 2. Ensure dependencies are installed
# -----------------------------
if [ ! -d "vendor" ]; then
  echo ""
  echo "📦 Installing dependencies..."
  composer install --no-interaction --prefer-dist --no-progress
fi

# -----------------------------
# 3. Run PHPCS
# -----------------------------
PROJECT_ROOT=$(git rev-parse --show-toplevel)

run_check "🔎 Running PHPCS..." \
  vendor/bin/phpcs "$PROJECT_ROOT"

# -----------------------------
# 4. Run PHPStan
# -----------------------------
run_check "🧠 Running PHPStan..." \
  vendor/bin/phpstan analyse --no-progress

# -----------------------------
# 5. Run PHPUnit
# -----------------------------
run_check "🧪 Running PHPUnit..." \
  vendor/bin/phpunit --colors=never --testdox

# -----------------------------
# 6. Validate tag version
# -----------------------------
while read local_ref local_sha remote_ref remote_sha
do
  if [[ "$local_ref" == refs/tags/* ]]; then

    TAG_NAME=${local_ref#refs/tags/}
    TAG_VERSION=${TAG_NAME#v}

    echo ""
    echo "🏷️ Validating tag: $TAG_NAME"

    if [ ! -f "$PLUGIN_FILE" ]; then
      echo "❌ Plugin file not found: $PLUGIN_FILE"
      exit 1
    fi

    PLUGIN_VERSION=$(php -r "
      \$contents = file_get_contents('$PLUGIN_FILE');
      if (preg_match('/Version:\s*([0-9.]+)/i', \$contents, \$m)) {
        echo \$m[1];
      }
    ")

    echo "Tag version: $TAG_VERSION"
    echo "Plugin version: $PLUGIN_VERSION"

    if [ "$PLUGIN_VERSION" != "$TAG_VERSION" ]; then
      echo "❌ Version mismatch! Push blocked."
      exit 1
    fi

    echo "✅ Version match confirmed"
  fi
done

# -----------------------------
# 7. Build check (only for tags)
# -----------------------------
TAG=$(git describe --exact-match --tags HEAD 2>/dev/null || true)

if [ -n "$TAG" ]; then

  echo ""
  echo "🏷️ Tag detected: $TAG"

  run_check "📦 Testing build process..." \
    composer run build

  if [ ! -f "$BUILD_ZIP" ]; then
    echo "❌ Build artifact missing: $BUILD_ZIP"
    exit 1
  fi

  echo "✅ Build successful"

else
  echo ""
  echo "ℹ️ No tag detected — skipping build check."
fi

echo ""
echo "🎉 All pre-push checks passed. Safe to push!"