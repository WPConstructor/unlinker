#!/bin/bash

echo "🚀 Running pre-push checks..."

# -----------------------------
# 1. Ensure working tree is clean
# -----------------------------
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo ""
  echo "❌ Your working tree is not clean."
  echo "👉 Commit or stash your changes before pushing."
  exit 1
fi

# -----------------------------
# 2. Ensure dependencies are installed
# -----------------------------
if [ ! -d "vendor" ]; then
  echo ""
  echo "📦 Installing dependencies..."
  composer install --no-interaction --prefer-dist --no-progress || exit 1
fi

# -----------------------------
# 3. Run PHPCS
# -----------------------------
echo ""
echo "🔎 Running PHPCS..."
vendor/bin/phpcs
if [ $? -ne 0 ]; then
  echo "❌ PHPCS failed. Fix coding standard issues."
  exit 1
fi

# -----------------------------
# 4. Run PHPStan
# -----------------------------
echo ""
echo "🧠 Running PHPStan..."
vendor/bin/phpstan analyse --no-progress
if [ $? -ne 0 ]; then
  echo "❌ PHPStan failed. Fix static analysis issues."
  exit 1
fi

# -----------------------------
# 5. Run PHPUnit
# -----------------------------
echo ""
echo "🧪 Running PHPUnit..."
vendor/bin/phpunit --colors=always
if [ $? -ne 0 ]; then
  echo "❌ PHPUnit tests failed."
  exit 1
fi

# -----------------------------
# 6. Validate tag version (if pushing a tag)
# -----------------------------
while read local_ref local_sha remote_ref remote_sha
do
  if [[ "$local_ref" == refs/tags/* ]]; then
    TAG_NAME=${local_ref#refs/tags/}
    TAG_VERSION=${TAG_NAME#v}

    echo ""
    echo "🏷️ Validating tag: $TAG_NAME"

    FILE="wpcn-unlinker.php"

    if [ ! -f "$FILE" ]; then
      echo "❌ Plugin file not found: $FILE"
      exit 1
    fi

    PLUGIN_VERSION=$(php -r '
      $contents = file_get_contents("wpcn-unlinker.php");
      if (preg_match("/Version:\s*([0-9.]+)/i", $contents, $m)) {
        echo $m[1];
      }
    ')

    echo "Tag version: $TAG_VERSION"
    echo "Plugin version: $PLUGIN_VERSION"

    if [ "$PLUGIN_VERSION" != "$TAG_VERSION" ]; then
      echo "❌ Version mismatch! Push blocked."
      exit 1
    fi

    echo "✅ Version match confirmed"
  fi
done

# -----------------------------
# 7. Build check
# -----------------------------
echo ""
echo "📦 Testing build process..."
composer run build
if [ $? -ne 0 ]; then
  echo "❌ Build failed."
  exit 1
fi

if [ ! -f "build/wpcn-unlinker.zip" ]; then
  echo "❌ Build artifact missing."
  exit 1
fi

echo "✅ Build successful"

echo ""
echo "🎉 All pre-push checks passed. Safe to push!"
