<?xml version="1.0"?>
<ruleset name="Project">

    <!-- Scan your project -->
    <file>.</file>

    <!-- Exclude vendor -->
    <exclude-pattern>vendor/*</exclude-pattern>

    <!-- Optional: also exclude build/logs -->
    <exclude-pattern>build/*</exclude-pattern>
    <exclude-pattern>node_modules/*</exclude-pattern>

    <!-- WordPress standard -->
    <rule ref="WordPress"/>

</ruleset>